# ==============================
# Database (Neon / Postgres)
# ==============================
# Pooler (produção)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&pgbouncer=true"

# Conexão direta (prisma migrate/dev)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# ==============================
# Cloudflare R2
# ==============================
R2_ACCOUNT_ID="SEU_ACCOUNT_ID"
R2_ACCESS_KEY_ID="SUA_ACCESS_KEY_ID"
R2_SECRET_ACCESS_KEY="SUA_SECRET_ACCESS_KEY"
R2_BUCKET_NAME="arquivos-educacionais"
R2_ENDPOINT="SEU_R2_ENDPOINT"
