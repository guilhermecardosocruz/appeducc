generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ClassSchedule {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  dayOfWeek Int
  period    String
  startTime String
  endTime   String

  createdAt DateTime @default(now())
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  cpf                  String?             @unique
  passwordHash         String
  isTeacher            Boolean             @default(false)
  createdById          String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  createdBy            User?               @relation("CreatedUsers", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers         User[]              @relation("CreatedUsers")
  sessions             Session[]
  groupMembers         GroupMember[]
  schoolMembers        SchoolMember[]
  classes              Class[]             @relation("ClassTeacher")
  galleryImagesUploaded ClassGalleryImage[] @relation("GalleryImageUploadedBy")

  deletedStudents      Student[]           @relation("DeletedByUser")
  deletedArchives      DeletedStudentArchive[]
}

model Session {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
}

model Group {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  members      GroupMember[]
  schools      School[]
  contents     GroupContent[]
  contentPlans ContentPlan[]
}

model GroupMember {
  id               String   @id @default(cuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  group            Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId          String

  role             String
  canManageSchools Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@unique([userId, groupId])
}

model School {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  group     Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  groupId   String

  members   SchoolMember[]
  classes   Class[]
}

model SchoolMember {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId  String

  role      String
  createdAt DateTime @default(now())

  @@unique([userId, schoolId])
}

model Class {
  id               String              @id @default(cuid())
  name             String
  year             Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  school           School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  schoolId         String

  teacher          User?               @relation("ClassTeacher", fields: [teacherId], references: [id])
  teacherId        String?

  students         Student[]
  attendances      Attendance[]
  contents         Content[]
  contentPlanLinks ContentPlanClass[]
  galleryImages    ClassGalleryImage[]
  deletedArchives  DeletedStudentArchive[]
  schedules        ClassSchedule[]
}

model Student {
  id            String               @id @default(cuid())
  name          String
  status        String               @default("ACTIVE")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  class         Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId       String

  presences     AttendancePresence[]

  deletedAt     DateTime?
  deletedReason String?
  deletedById   String?
  deletedBy     User?                @relation("DeletedByUser", fields: [deletedById], references: [id])
}

model DeletedStudentArchive {
  id                   String   @id @default(cuid())
  name                 String
  classId              String
  class                Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  entryDate            DateTime?
  exitDate             DateTime
  attendancePercentage Float?
  exitReason           String?
  deletedById          String?
  deletedBy            User?    @relation(fields: [deletedById], references: [id])

  createdAt            DateTime @default(now())
}

model Attendance {
  id         String               @id @default(cuid())
  title      String
  lessonDate DateTime
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  class      Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId    String

  content    Content?             @relation(fields: [contentId], references: [id], onDelete: SetNull)
  contentId  String?

  presences  AttendancePresence[]
}

model AttendancePresence {
  id           String      @id @default(cuid())
  present      Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  attendance   Attendance  @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  attendanceId String

  student      Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId    String

  @@unique([attendanceId, studentId])
}

model Content {
  id                        String              @id @default(cuid())
  title                     String
  objectives                String?
  methodology               String?
  resources                 String?
  bncc                      String?
  isCustomized              Boolean             @default(false)

  class                     Class               @relation(fields: [classId], references: [id], onDelete: Cascade)
  classId                   String

  attendances               Attendance[]

  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
}

model GroupContent {
  id          String   @id @default(cuid())
  title       String
  description String?
  objectives  String?
  methodology String?
  resources   String?
  bncc        String?

  groupId     String
  group       Group    @relation(fields: [groupId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContentPlan {
  id              String              @id @default(cuid())
  name            String
  description     String?

  groupId         String
  group           Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)

  lessons         ContentPlanLesson[]
  classLinks      ContentPlanClass[]

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model ContentPlanLesson {
  id               String       @id @default(cuid())
  orderIndex       Int
  title            String
  objectives       String?
  methodology      String?
  resources        String?
  bncc             String?

  contentPlanId    String
  contentPlan      ContentPlan  @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([contentPlanId, orderIndex])
}

model ContentPlanClass {
  id            String      @id @default(cuid())

  contentPlanId String
  contentPlan   ContentPlan @relation(fields: [contentPlanId], references: [id], onDelete: Cascade)

  classId       String
  class         Class       @relation(fields: [classId], references: [id], onDelete: Cascade)

  status        String      @default("LINKED")
  linkedAt      DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([contentPlanId, classId])
}

model ClassGalleryImage {
  id           String   @id @default(cuid())
  classId      String
  class        Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User     @relation("GalleryImageUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)

  objectKey    String   @unique
  fileName     String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())
}

model AlertSeen {
  id          String   @id @default(cuid())
  userId      String
  classId     String
  studentId   String
  seenAt      DateTime?
  dismissedAt DateTime?

  @@unique([userId, classId, studentId])
}

model GroupBackup {
  id        String   @id @default(cuid())
  groupId   String
  data      Json
  createdAt DateTime @default(now())

  @@index([groupId])
}
